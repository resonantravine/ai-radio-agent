# mock, openai, or gemini
LLM_PROVIDER=mock

# Optional: override provider model.
# Gemini low-cost/free-tier-friendly examples:
# LLM_MODEL=gemini-3.1-flash-lite
# LLM_MODEL=gemini-2.0-flash-lite
#
# OpenAI example:
# LLM_MODEL=gpt-5.5

OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional ElevenLabs TTS export.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# Pick clearly different voices from:
# python3 -m ai_radio_agent.tts_elevenlabs --list-voices
ELEVENLABS_HOST_A_VOICE_ID=wWWn96OtTHu1sn8SRGEr
ELEVENLABS_HOST_B_VOICE_ID=r1KmysJdVYZjJCm4mL3b
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Optional output directory. Defaults to ./outputs
OUTPUT_DIR=outputs
